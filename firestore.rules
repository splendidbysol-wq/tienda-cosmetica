rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: ¿el usuario está autenticado y es el vendedor/admin?
    function esVendedor() {
      return request.auth != null;
      // Más adelante se puede restringir por email específico o custom claim:
      // return request.auth != null && request.auth.token.email == 'vendedor@negocio.com';
    }

    // Helper: ¿esta escritura es SOLO un descuento válido de stock?
    // Esto es lo que permite que un cliente (sin login) confirme un pedido
    // y descuente stock, sin poder tocar precio, nombre, ni ningún otro campo.
    function esDescuentoDeStockValido() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'actualizadoEn'])
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0
        && request.resource.data.stock < resource.data.stock;
    }

    // PRODUCTOS: catálogo público de lectura, escritura solo del vendedor
    // (con la excepción puntual del descuento de stock en el checkout)
    match /productos/{productoId} {
      allow read: if true; // cualquiera puede ver el catálogo
      allow create, delete: if esVendedor();

      allow update: if esVendedor()
        && request.resource.data.precio is number
        && request.resource.data.precio >= 0
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0;

      allow update: if esDescuentoDeStockValido();
    }

    // PEDIDOS: cualquiera puede crear un pedido (cliente comprando),
    // pero solo el vendedor puede leer/editar/borrar todos los pedidos.
    match /pedidos/{pedidoId} {
      allow create: if request.resource.data.total is number
        && request.resource.data.total > 0
        && request.resource.data.productos is list
        && request.resource.data.productos.size() > 0;
      allow read, update, delete: if esVendedor();
    }

    // CONFIG: datos del local (nombre, colores, métodos de pago)
    match /config/{docId} {
      allow read: if true; // el frontend necesita leer esto públicamente
      allow write: if esVendedor();
    }
  }
}
